{
  "name": "story-mapper",
  "private": true,
  "version": "0.0.0",
  "description": "Story Mapper monorepo",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  }
}
