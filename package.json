{
  "name": "story-mapper",
  "private": true,
  "version": "0.0.0",
  "description": "A canvas-based story mapping tool for creating technical and functional requirements.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
