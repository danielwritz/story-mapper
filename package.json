  "bugs": {
    "url": "https://github.com/danielwritz/story-mapper/issues"
  },
  "homepage": "https://github.com/danielwritz/story-mapper#readme",
  "devDependencies": {
    "@types/node": "^22.7.4",
    "typescript": "~5.9.3",
    "vitest": "^1.6.0"
  }
}
